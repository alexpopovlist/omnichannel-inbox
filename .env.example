PORT=8080
LOG_LEVEL=info
PUBLIC_BASE_URL=http://localhost:8080

# Postgres (dev/prod). Example for local Postgres:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inbox?schema=public


# and use something like:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inbox?schema=public

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Instagram / Meta Webhooks
INSTAGRAM_VERIFY_TOKEN=
# Used to validate X-Hub-Signature-256 (HMAC SHA-256). If empty, signature validation is skipped.
INSTAGRAM_APP_SECRET=

# Instagram DM sending (Messenger API for Instagram)
# Page access token (or System User token with permissions to message)
INSTAGRAM_PAGE_ACCESS_TOKEN=
# Optional, may be useful for debugging / future features
INSTAGRAM_PAGE_ID=

# Required: page company id used to fetch Instagram conversations
# Example from user: 1010177955516362
INSTAGRAM_PAGE_COMPANY_ID=

# Optional: your own Instagram business user id inside participants (helps determine outbound/inbound in sync)
INSTAGRAM_IG_USER_ID=
# Graph API version
META_GRAPH_VERSION=v25.0
